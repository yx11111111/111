def modified_gaisser(E_mu, cos_theta):
    P1, P2, P3, P4, P5 = 0.102573, -0.068287, 0.958633, 0.0407253, 0.817285
    cos_theta_star = np.sqrt(
        (cos_theta**2 + P1**2 + P2*cos_theta**P3 + P4*cos_theta**P5)
        / (1 + P1**2 + P2 + P4)
    )
    E_mu_star = E_mu * (1 + 3.64 / (E_mu * cos_theta_star**1.29))
    term1 = 1 / (1 + 1.1 * E_mu * cos_theta_star / 115)
    term2 = 0.054 / (1 + 1.1 * E_mu * cos_theta_star / 850)
    return 0.14 * (E_mu_star ** (-2.7)) * (term1 + term2)

def energy_theoretical(E):
    return integrate.quad(lambda ct: modified_gaisser(E, ct), 0.342, 1)[0]

def cos_theoretical(ct):
    return integrate.quad(lambda E: modified_gaisser(E, ct), 1, 1000)[0]

def generate_muon_samples(num_samples=10000, E_min=1e2, E_max=1e4, theta_bins=1000, E_bins=1000):
    E_edges = np.linspace(E_min, E_max, E_bins + 1)
    cos_theta_edges = np.linspace(0.342, 1, theta_bins + 1)
    E_centers = (E_edges[:-1] + E_edges[1:]) / 2
    cos_theta_centers = (cos_theta_edges[:-1] + cos_theta_edges[1:]) / 2

    E_grid, theta_grid = np.meshgrid(E_centers, cos_theta_centers, indexing='ij')
    flux = np.vectorize(modified_gaisser)(E_grid, theta_grid)
    flux_flat = flux.flatten()  


    prob_flat = flux_flat / flux_flat.sum()
    cum_prob_flat = np.cumsum(prob_flat)
    u = np.random.rand(num_samples)
    idx = np.searchsorted(cum_prob_flat, u)

    energies = []
    cos_thetas = []
    for i in idx:
        e_idx = i // theta_bins
        t_idx = i % theta_bins
        energies.append(np.random.uniform(E_edges[e_idx], E_edges[e_idx+1]))
        cos_thetas.append(np.random.uniform(cos_theta_edges[t_idx], cos_theta_edges[t_idx+1]))
    
 
    return np.array(energies), np.array(cos_thetas)

