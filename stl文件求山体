def run_muon_in_mountain_fast(
    stl_file,
    detector_pos,
    zenith_angles,
    azimuth_angles,
    plot=True
):
    """
    高速版：仅计算缪子在山体 STL 内部的路径长度（无 bedrock）
    - 使用 float32 节省内存
    - 自动启用 Embree 加速射线求交
    - 接口与原函数完全一致
    """
    # --- 输入校验 ---
    if not os.path.exists(stl_file):
        raise FileNotFoundError(f"STL 文件不存在: {stl_file}")
    
    detector_pos = np.asarray(detector_pos, dtype=np.float32)  # ← 改为 float32
    zenith_angles = np.asarray(zenith_angles, dtype=np.float32)
    azimuth_angles = np.asarray(azimuth_angles, dtype=np.float32)

    if detector_pos.shape != (3,):
        raise ValueError("detector_pos 必须是 [x, y, z]")
    if zenith_angles.shape != azimuth_angles.shape:
        raise ValueError("角度数组形状必须一致")

    n_muons = zenith_angles.size
    if n_muons == 0:
        raise ValueError("角度数组不能为空")

    print(f"📍 探测器位置: {detector_pos}")
    print(f"🎯 使用 {n_muons:,} 条缪子轨迹...")

    # --- 构建射线 ---
    start_pos = np.tile(detector_pos, (n_muons, 1))
    sin_theta = np.sin(zenith_angles)
    directions = np.column_stack((
        sin_theta * np.cos(azimuth_angles),
        sin_theta * np.sin(azimuth_angles),
        np.cos(zenith_angles)
    ))
    directions /= np.linalg.norm(directions, axis=1, keepdims=True)

    # --- 加载模型 ---
    mesh = trimesh.load(stl_file)

    # --- 射线求交（Embree 会自动加速此步骤）---
    locations, index_ray, _ = mesh.ray.intersects_location(
        ray_origins=start_pos,
        ray_directions=directions,
        multiple_hits=True
    )

    # --- 初始化结果（float32）---
    mountain_lengths = np.zeros(n_muons, dtype=np.float32)
    entry_points = np.full((n_muons, 3), np.nan, dtype=np.float32)

    if len(locations) == 0:
        print("\n✅ 模拟完成! 无任何交点。")
        return entry_points, mountain_lengths

    # --- 向量化：计算距离 ---
    origins_for_hits = start_pos[index_ray]
    vectors = locations - origins_for_hits
    distances = np.linalg.norm(vectors, axis=1)

    # --- 排序 ---
    sort_key = index_ray.astype(np.int64) * (10**12) + distances.astype(np.float64)
    sort_idx = np.argsort(sort_key, kind='stable')
    index_ray_sorted = index_ray[sort_idx]
    distances_sorted = distances[sort_idx]
    locations_sorted = locations[sort_idx]

    # --- 分组处理 ---
    unique_rays, first_occurrence = np.unique(index_ray_sorted, return_index=True)
    split_distances = np.split(distances_sorted, first_occurrence[1:])
    split_locations = np.split(locations_sorted, first_occurrence[1:])

    # --- 计算每条射线的路径长度 ---
    for ray_id, dists, locs in zip(unique_rays, split_distances, split_locations):
        n_hits = len(dists)
        if n_hits == 0:
            continue

        total_len = 0.0
        if n_hits % 2 == 1:  # 起点在内部
            total_len += dists[0]
            for k in range(1, n_hits - 1, 2):
                total_len += dists[k + 1] - dists[k]
        else:  # 起点在外部
            for k in range(0, n_hits - 1, 2):
                total_len += dists[k + 1] - dists[k]

        mountain_lengths[ray_id] = total_len
        entry_points[ray_id] = locs[0]

    # --- 统计 ---
    valid_mask = mountain_lengths > 1e-5  # float32 精度稍低，阈值略放宽
    n_valid = np.count_nonzero(valid_mask)
    print(f"\n✅ 模拟完成!")
    print(f"   总射线数: {n_muons:,}")
    print(f"   击中山体: {n_valid:,} ({100 * n_valid / n_muons:.1f}%)")
    if n_valid > 0:
        print(f"   平均山体路径: {np.mean(mountain_lengths[valid_mask]):.2f} m")
        print(f"   路径范围: [{np.min(mountain_lengths[valid_mask]):.2f}, {np.max(mountain_lengths[valid_mask]):.2f}] m")

    # --- 绘图 ---
    if plot and n_valid > 0:
        _plot_results(mesh, detector_pos, entry_points, mountain_lengths)

    return entry_points, mountain_lengths

